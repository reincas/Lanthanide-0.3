/blue      { 0.0 0.0 1.0 setrgbcolor } bind def
/darkblue  { 0.0 0.0 0.7 setrgbcolor } bind def
/lightblue { 0.0 1.0 1.0 setrgbcolor } bind def
%%EndProlog

