100 dict begin
%%BeginProlog
%%% x y len rot lw color  <Line>  -
  /Line { gsave cvx exec
    5 3 roll translate setlinewidth 0 setlinecap rotate
    0 0 moveto 0 lineto stroke
  grestore } def 
%%% <Line>
%%% name  <edef> -
  /edef { exch def } def
%%% <edef>
%%% scale  <arrowhead> -
  /arrowhead { 1 dict begin
    0 0 moveto -13 s mul 4 s mul lineto
    -11 s mul 0 lineto -13 s mul -4 s mul lineto
    closepath fill
  end } def
%%% <arrowhead>
%%% arc prog1 prog2 prog3 prog4  <quadrant> -
  /quadrant { 5 dict begin
    /p4 exch def /p3 exch def /p2 exch def /p1 exch def
    /a exch def
    a 90 lt {p1} { a 180 lt {p2} { a 270 lt {p3} {p4}
      ifelse } ifelse } ifelse
  end } def
%%% <quadrant>
%%% x y len rot lw scale color  <Arrow>  -
  /Arrow { gsave cvx exec 1 dict begin
    /s exch def
    5 3 roll translate setlinewidth 0 setlinecap rotate
    dup 0 0 moveto s 11 mul sub 0 lineto stroke
    0 translate
    arrowhead
  end grestore } def
%%% <Arrow>
%%% x y len rot lw scale color  <Darrow>  -
  /Darrow { gsave cvx exec 1 dict begin
    /s exch def
    5 3 roll translate setlinewidth 0 setlinecap
    [10 5] 0 setdash rotate
    dup 0 0 moveto s 11 mul sub 0 lineto stroke
    0 translate
    arrowhead
  end grestore } def
%%% <Darrow>
%%% x y len1 num r len2 rot lw scale color  <Carrow>  -
  /Carrow { gsave cvx exec 8 dict begin
    /s edef /w edef /d edef /l2 edef /r edef /n edef /l1 edef
    translate w setlinewidth 0 setlinecap d rotate
    0 0 moveto l1 w 2 div add 0 lineto stroke
    l1 0 translate
    1 1 n { /i edef 0 0 moveto r 0 r
      i dup 2 idiv 2 mul eq { 180 0 arc } { 180 0 arcn } ifelse
      r 2 mul 0 translate
    } for
    w -2 div 0 l2 0 w s Arrow
  end grestore } def
%%% <Carrow>
%%% x y len rot lw scale color  <Marrow>  -
  /Marrow { gsave cvx exec 6 dict begin
    /s exch def
    setlinewidth 0 setlinecap
    /rot exch dup sin exch cos atan def
    /d exch 2 div def translate
    rot dup dup 180 sub dup rot quadrant rotate
    rot d d neg dup d quadrant 0 translate
    rot 90 rot sub rot 90 sub 270 rot sub rot 270 sub quadrant
    /beta exch 0.5 mul def
    /r d beta sin div def
    0 r beta cos mul neg r 90 beta sub 90 beta add arc stroke
    rot d d neg dup d quadrant 0 translate
    /betas beta 5.5 s mul r atan sub def
    rot betas neg 180 betas add dup betas neg quadrant rotate
    arrowhead
  end grestore } def
%%% <Marrow>
%%% string x y font  <Show>  -
  /Show { setfont moveto show } def
%%% <Show>
/black     { 0.0 0.0 0.0 setrgbcolor } bind def
/white     { 1.0 1.0 1.0 setrgbcolor } bind def
/red       { 1.0 0.0 0.0 setrgbcolor } bind def
